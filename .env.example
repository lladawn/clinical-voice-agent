# LiveKit (https://cloud.livekit.io — free tier)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Deepgram Nova-3 Medical (STT)
DEEPGRAM_API_KEY=

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=

# TTS — Cartesia (free tier). ElevenLabs also supported; see pipeline.py
CARTESIA_API_KEY=
# ELEVENLABS_API_KEY=

# Supabase (audit log storage — used by the app at runtime)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Supabase CLI (ONLY needed to apply DB migrations via `supabase db push`;
# the running app does not use these)
SUPABASE_ACCESS_TOKEN=     # personal token: https://supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=      # Settings -> General -> Reference ID (e.g. abcdefghijklmno)
SUPABASE_DB_PASSWORD=      # database password (for non-interactive `db push`)

# Backend
BACKEND_PORT=8000

# Optional feature flags (off by default)
# SEMANTIC_GUARDRAIL=1          # enable the semantic (Layer 1) safety classifier
# SEMANTIC_GUARDRAIL_GATED=1    # latency-first: only run Layer 1 on risky-looking turns
# GROUNDED_MODE=1               # citation-forced answers + abstention (grounded RAG)
