# Server-side env for the Next.js API routes (/api/token, /api/audit-log).
# These are NOT exposed to the browser. On Vercel, set the same vars in
# Project Settings -> Environment Variables.

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
